---
layout: base
permalink: /index.html
title: 'This is ZooBOTix'
description: 'ZooBOTix is a K-12 STEM program in Kalamazoo, Michigan, teaching teamwork and leadership through four levels of FIRST robotics: FLLE, FLLC, FTC, and FRC.'
blog: 'Blog'
intro: "I'm showing the last 4 blog posts, but there might be more!"
---

<div class="wrapper">
  <header class="full | section" style="--spot-color: var(--color-primary); 
              background-blend-mode: multiply;">
    <div class="section__inner">
      <div class="hero" data-variant="dimmed masked">
        <img src="/assets/images/worlds_team_photo.jpg" alt="2025 Worlds ZooBOTix Team Photo" class="hero__image">

        <h1 class="hero__title shadow-halo" style="fontSize: var(--size-step-5);
            --color-text: white">
          {{ title }}
        </h1>
        {# Buttons for navigating to different teams #}
        <div class="hero__actions">
          <a href="/about/FRC/" class="button" data-button-variant="primary">FRC</a>
          <a href="/about/FTC/" class="button" data-button-variant="primary">FTC</a>
          <a href="/about/FLL/" class="button" data-button-variant="primary">FLL</a>
        </div>
      </div>
    </div>

    <div class="section__inner flow region" id="slogan">
      <h2 class="fly-in" style="color: white; text-align: center"><em>Fail Fast</em></h2>
      <h2 class="fly-in" style="color: white; text-align: center"><em>Fail Frequently</em></h2>
      <h2 class="fly-in" style="color: white; text-align: center"><em>Fail Forward</em></h2>
    </div>
    {% svg "divider/pixels", null, "divider" %}
  </header>

  <article class="full | region">
    <div class="prose wrapper flow">
      <h2 id="who-are-we">Who Are We?</h2>
      <p>
        We are a K-12 STEM program teaching to the youth not only STEM skills but teamwork, social skills and teamwork and we have the end goal to have our participants become leaders in STEM. We vary through 4 different levels 
        <a href="/about/FLL/#explore">FLLE k-3</a>, 
        <a href="/about/FLL/#challenge">FLLC 4-5</a>, 
        <a href="/about/FTC/">FTC 6-8</a> 
        and 
        <a href="/about/FRC/">FRC 9-12</a>, for more info on each specific level check out their respective sections. Each level will go to their own respective competitions of sorts where there will be 20-40 other teams from as close as Kalamazoo or as far Europe. This program aims to teach and inspire the youth and provide opportunities in STEM.
      </p>
    </div>
  </article>

  <section class="full | region">
    <div class="prose wrapper flow">
      <h2>{{ blog.title }}</h2>
      {% if blog.intro %}
      <p>{{ blog.intro }}</p>
      {% endif %}
      <div class="feature |  region region-space-l">
        <custom-masonry layout="50-50">
          {% set itemList = collections.allPosts %}
          {% asyncEach item in itemList.slice(0, 4) %}
          {% set headingLevel = "h3" %}
          {% include "partials/card-blog.njk" %}
          {% endeach %}
        </custom-masonry>
      </div>
    </div>
  </section>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const flyInElements = document.querySelectorAll(".fly-in");

    const observerCallback = (entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    }

    const observerOptions = {
      root: null,
      rootMargin: "0px",
      threshold: 0.1
    };

    const observer = new IntersectionObserver(observerCallback, observerOptions);

    flyInElements.forEach((element, index) => {
      element.style.transitionDelay = `${index * 0.2}s`;
      observer.observe(element);
    });
  });
</script>
